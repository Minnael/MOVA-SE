{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(cat *.env*)",
      "Bash(cat *.env)",
      "Bash(less *.env*)",
      "Bash(head *.env*)",
      "Bash(tail *.env*)"
    ]
  },
  "sandbox": {
    "filesystem": {
      "denyRead": [
        "./.env",
        "./.env.*"
      ]
    }
  }
}
